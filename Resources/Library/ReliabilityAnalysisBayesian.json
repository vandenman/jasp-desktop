{
	"name": "ReliabilityAnalysisBayesian",
	"autorun": true,
	"version": "2.00",
	"jaspResults": true,
	"options": [
    {
      "name": "variables",
      "type": "Variables"
    },
    {
    	"name": "alphaScale",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "gutmann2Scale",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "gutmann6Scale",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "mcDonaldScale",
    	"type": "Boolean",
			"default" : true
    },
    {
    	"name": "glbScale",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "meanScale",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "sdScale",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "alphaItem",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "gutmannItem",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "mcDonaldItem",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "meanItem",
    	"type": "Boolean",
			"default" : false
    },
    {
    	"name": "sdItem",
    	"type": "Boolean",
			"default" : false
    },
    {
      "name": "reverseScaledItems",
      "type": "Variables"
    },
    {
      "name": "missingValues",
      "options": ["excludeCasesListwise", "excludeCasesPairwise"],
      "default": "excludeCasesListwise",
      "type": "List"
    },
    {
    	"name": "plotPosterior",
    	"type": "Boolean",
		"default" : false
    }
	]
}
